{
  "$schema": "https://railway.app/railway.schema.json",
  "variables": {
    "NIXPACKS_NODE_VERSION": "20"
  },
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install"
  },
  "deploy": {
    "startCommand": "cd backend && node server.mjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
